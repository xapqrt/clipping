{
    "manifest_version": 3,
    "name": "Brain=Sync",
    "version": "0.1.0",
    "description": "local-first  sematic web clipper - runs emeddings on- device via transfromer.js",
    "permissions": [
        "activeTab",
        "contextMenus",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Brain-Sync - Search your clips"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "node_modules/@huggingface/transformers/dist/*.wasm",
                    "dist/*.wasm",
                "*.wasm"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}