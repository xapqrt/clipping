{
    "manifest_version": 3,
    "name": "Clipper",
    "version": "0.0.1",
    "description": "Local-first semantic web clipper",
    "permissions": ["storage", "activeTab", "scripting", "contextMenus", "tabs"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Clipper"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
         "resources": ["*.wasm", "wasm/*", "models/*", "vendor/*"],
            "matches": ["<all_urls>"]
        }
    ]
}